# Hybrid Input Mode Configuration
# Set to true to use laptop camera (YOLO) for WEST road detection
USE_CAMERA_WEST=false

# Camera device index (0 = default/built-in camera, 1+ for external cameras)
WEST_CAMERA_INDEX=0

# Path to YOLO model weights
WEST_MODEL_PATH=backend/models/best.pt

# YOLO confidence threshold (0.0-1.0)
WEST_CONF=0.30

# WEST Metrics Configuration (Task 2)
# ROI for WEST camera as "x1,y1,x2,y2" (empty = full frame)
WEST_ROI=

# Enable rolling smoothing of vehicle counts (reduces flicker)
WEST_SMOOTHING_ENABLED=true

# Number of frames to keep for rolling smoothing
WEST_SMOOTHING_WINDOW=5

# Resize frame width for faster YOLO processing (0 = no resize)
WEST_RESIZE_WIDTH=640

# WEST Source Mode Configuration (Task 3)
# Source mode: "webcam" (default) or "video" file
WEST_SOURCE_MODE=webcam

# Path to video file (required if WEST_SOURCE_MODE=video)
WEST_VIDEO_PATH=

# Loop video when it ends (only applies to video mode)
WEST_LOOP_VIDEO=false

# Database Configuration (MongoDB)
MONGO_URI=mongodb+srv://rolexultimate23_db_user:qwerty12345@cluster0.axqeteq.mongodb.net/?appName=Cluster0
DB_NAME=EmergencyDetection
COLLECTION_NAME=Detections
